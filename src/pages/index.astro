---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import Newsletter from "../components/Newsletter.jsx";
import OrdoVivens from "../components/OrdoVivens.astro";

import "../styles/global.css";
---

<!DOCTYPE html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body
		class="bg-blueprint-blue text-blueprint-white selection:bg-blueprint-gold selection:text-blueprint-blue"
	>
		<Header />
		<main class="relative overflow-hidden pt-20 pb-32 px-6">
			<!-- Background decorative element: Blueprint Grid -->
			<div
				class="absolute inset-0 z-0 opacity-10 pointer-events-none"
				style="background-image: radial-gradient(circle, #F5F5F0 1px, transparent 1px); background-size: 40px 40px;"
			>
			</div>

			<div
				class="relative z-10 max-w-5xl mx-auto flex flex-col items-center text-center"
			>
				<h1
					class="text-7xl md:text-8xl font-black tracking-tighter mb-8 leading-none"
				>
					Simon<span class="text-blueprint-gold">ᚼL</span>
				</h1>

				<p
					class="text-xl md:text-2xl text-blueprint-gray max-w-3xl mb-4 leading-relaxed font-mono"
				>
					Maestría de <span class="text-blueprint-white font-bold"
						>Soberanía Personal</span
					> y sistemas digitales de alto rendimiento. Construyendo el futuro
					de la libertad individual.
				</p>

				<OrdoVivens />

				<div class="flex flex-wrap justify-center gap-6 mb-20 mt-8">
					<a
						href="/blog"
						class="bg-blueprint-gold text-blueprint-blue px-10 py-5 rounded-sm font-black uppercase tracking-widest hover:scale-105 transition-all shadow-[8px_8px_0px_0px_rgba(245,245,240,0.1)] active:translate-y-1 active:shadow-none"
					>
						Explorar Codex
					</a>
					<a
						href="https://github.com/simonpedro33"
						target="_blank"
						class="border border-white/20 text-blueprint-white px-10 py-5 rounded-sm font-bold uppercase tracking-widest hover:bg-white/5 transition-all"
					>
						Repositorio
					</a>
				</div>

				<div class="w-full">
					<Newsletter client:load />
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
