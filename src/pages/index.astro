---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import Newsletter from '../components/Newsletter.jsx';

import '../styles/global.css'; 
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-white text-gray-900 font-sans antialiased">
		<Header />
		<main class="flex flex-col items-center justify-center min-h-[70vh] px-6 text-center">
			<h1 class="text-6xl font-extrabold tracking-tighter mb-6">
				Simon<span class="text-blue-600 font-black">HL</span>
			</h1>
			
			<p class="text-xl text-gray-600 max-w-2xl mb-10 leading-relaxed">
				Especialista en <span class="text-black font-semibold text-gray-800">Maestría de Soberanía Personal</span> y sistemas digitales de alto rendimiento. Construyendo el futuro de la libertad individual.
			</p>

			<div class="flex flex-wrap justify-center gap-4">
				<a href="/blog" class="bg-black text-white px-8 py-4 rounded-full font-bold hover:bg-gray-800 transition-all shadow-lg hover:shadow-xl active:scale-95">
					Explorar Blog
				</a>
				<a href="https://github.com/simonpedro33" target="_blank" class="bg-gray-100 text-gray-900 px-8 py-4 rounded-full font-bold hover:bg-gray-200 transition-all">
					GitHub
				</a>
			</div>
			<Newsletter client:load />
		</main>
		<Footer />
	</body>
</html>