---
import HeaderLink from "./HeaderLink.astro";
import Search from "./Search.astro";
import Logo from "./Logo.astro";
---

<header class="sticky top-0 z-50 w-full bg-blueprint-blue/90 backdrop-blur-md border-b border-white/10 shadow-lg">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between gap-8">
    <!-- 1. IDENTIDAD (Izquierda) -->
    <div class="flex-shrink-0">
      <Logo />
    </div>

    <!-- 2. NAVEGACIÓN (Centro) -->
    <div class="hidden md:flex items-center justify-center space-x-2 font-mono">
      <HeaderLink href="/" class="px-4 py-2 rounded-lg text-sm uppercase tracking-widest transition-all">Home</HeaderLink>
      <HeaderLink href="/blog" class="px-4 py-2 rounded-lg text-sm uppercase tracking-widest transition-all">Codex</HeaderLink>
      <HeaderLink href="/about" class="px-4 py-2 rounded-lg text-sm uppercase tracking-widest transition-all">Sistema</HeaderLink>
    </div>

    <!-- 3. HERRAMIENTAS (Derecha) -->
    <div class="flex-shrink-0 min-w-[200px] md:min-w-[250px]">
      <Search />
    </div>
  </nav>
</header>

<style is:global>
  /* Usamos las variables de CSS directamente para evitar problemas de resolución de Tailwind en bloques de estilo aislados */
  nav a {
    color: var(--color-blueprint-gray);
  }

  nav a:hover {
    color: var(--color-blueprint-white);
    background-color: rgba(255, 255, 255, 0.05);
  }

  nav a.active {
    color: var(--color-blueprint-white);
    border: 1px solid rgba(245, 245, 240, 0.2);
    background-color: rgba(255, 255, 255, 0.1);
  }
</style>